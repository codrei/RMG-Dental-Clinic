rules_version = '2';

// RMG Dental Clinic — Firestore security rules
//
// The model:
//  - `bookings`     PRIVATE. Patients can only CREATE (submit a request,
//                   validated below). Only the signed-in clinic account can
//                   read, update, or delete them.
//  - `bookedSlots`  PUBLIC but personal-data-free ({date, time} only).
//                   The calendar reads it to grey out taken times. Its doc
//                   ID (`YYYY-MM-DD_HHMM`) acts as a lock: create-only means
//                   two patients can never take the same slot. Only the
//                   clinic can delete (freeing a slot after a decline).
//  - `settings`     PUBLIC read (future: days off shown in the calendar),
//                   clinic-only writes.

service cloud.firestore {
  match /databases/{database}/documents {

    function isClinic() {
      return request.auth != null;
    }

    function validBooking() {
      let d = request.resource.data;
      return d.status == 'pending'
        && d.patientName is string && d.patientName.size() >= 2 && d.patientName.size() <= 80
        && d.phone is string && d.phone.size() >= 7 && d.phone.size() <= 20
        && d.serviceSlug is string && d.serviceSlug.size() <= 40
        && d.serviceName is string && d.serviceName.size() <= 80
        && d.durationMinutes is int && d.durationMinutes > 0 && d.durationMinutes <= 240
        && d.date is string && d.date.matches('\\d{4}-\\d{2}-\\d{2}')
        && d.time is string && d.time.matches('\\d{2}:\\d{2}')
        && (!('email' in d) || (d.email is string && d.email.size() <= 100))
        && (!('notes' in d) || (d.notes is string && d.notes.size() <= 500));
    }

    match /bookings/{bookingId} {
      allow create: if validBooking();
      allow read, update, delete: if isClinic();
    }

    match /bookedSlots/{slotId} {
      allow read: if true;
      // create-only: an existing slot doc can never be overwritten
      allow create: if request.resource.data.keys().hasOnly(['date', 'time'])
        && request.resource.data.date is string
        && request.resource.data.time is string
        && slotId == request.resource.data.date + '_' + request.resource.data.time.replace(':', '');
      allow update: if false;
      allow delete: if isClinic();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isClinic();
    }
  }
}
